{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mganga",
  "version": "0.1.1",
  "identifier": "com.mganga.app",
  "mainBinaryName": "mganga",
  "build": {
    "beforeDevCommand": "cargo build --manifest-path=src-tauri/Cargo.toml --bin mganga-broker && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mganga",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/SeedeXR/mganga/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyODE5NjMwRjMwRTE5ODAKUldTQUdRN3pNSmFCa3FqOWp5L2U1M2ZqYU5BS0dTbGR3YlN4RGFZR3FIT0pISjFLcnAxT3d1TlgK"
    }
  }
}
